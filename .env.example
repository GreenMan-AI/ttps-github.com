# Nokopē šo failu par ".env" un ievieto savas vērtības.
# Uz Render.com tās jāievieto zem "Environment" cilnes (nevis šajā failā).

# MongoDB savienojuma virkne (piem. no MongoDB Atlas)
MONGODB_URI=mongodb+srv://lietotajs:parole@cluster.mongodb.net/soundpulse

# Cloudinary — bilžu un mūzikas glabāšanai (bezmaksas konts pietiek sākumam)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin konta pieejas dati — OBLIGĀTI NOMAINI uz kaut ko savu!
ADMIN_USER=admin
ADMIN_PASS=main-parole-123

# Ports (Render to iestata automātiski, lokāli var atstāt 3000)
PORT=3000

# SVARĪGI drošībai: iestati uz "production", kad lapa darbojas ar īstu domēnu
# un HTTPS (piem. Render). Tas liek admin sesijas cookie sūtīt tikai pa HTTPS.
# Lokālai izstrādei (http://localhost) atstāj tukšu vai "development".
NODE_ENV=production

# Nav obligāti — vajadzīgs TIKAI, ja kāds cits domēns (ne pati lapa) drīkst
# sūtīt pieprasījumus ar admin sesiju (piem. atsevišķa admin lietotne).
# Parastai lapas lietošanai var atstāt tukšu. Vairāki domēni — atdalīt ar komatu.
ALLOWED_ORIGINS=
